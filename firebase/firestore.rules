rules_version = '2';

// Firestore Security Rules for Minna de Quiz
service cloud.firestore {
  match /databases/{database}/documents {
    match /rooms/{roomId} {
      allow read: if true;
      // Firebase Admin SDK (Functions) からの書き込みは rules を無視するため、
      // クライアントからの書き込みのみルールで制御する
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'deleteEligibleAt',
          'cleanupState',
          'cleanupReason',
          'lastCleanupDecisionAt'
        ]);
      allow delete: if false;

      match /players/{playerId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null;
      }

      match /questions/{questionId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null;
      }

      match /answers/{answerId} {
        allow read, write: if request.auth != null;
      }

      match /predictions/{predictionId} {
        allow read, write: if request.auth != null;
      }

      match /gameState/{stateId} {
        allow read: if true;
        // クライアントは markPlayerReady, initializeGame のみ書き込み可
        // Functionsによる phase/onlinePlayerIds 更新は admin SDK 経由で rules をバイパス
        allow create, update, delete: if request.auth != null;
      }
    }

    match /answers/{answerId} {
      allow read, write: if request.auth != null;
    }

    match /predictions/{predictionId} {
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}